{
  "name": "agent-traffic-light",
  "private": true,
  "version": "1.6.3",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "dev": "concurrently -k \"npm run dev:vite\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "build": "vite build",
    "start": "npm run build && electron .",
    "watch": "rm -rf dist && NO_PROXY=localhost npx electron .",
    "dist": "npm run build && electron-builder --mac dmg --publish never",
    "dist:win": "npm run build && electron-builder --win nsis --publish never"
  },
  "build": {
    "appId": "com.ai.traffic-light",
    "productName": "Agent 红绿灯",
    "copyright": "Copyright © 2025",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "title": "Agent 红绿灯",
      "window": { "width": 540, "height": 380 }
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tw-animate-css": "^1.3.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "^8.2.2",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "tailwindcss": "4.1.12",
    "typescript": "^5.5.2",
    "vite": "6.3.5",
    "wait-on": "^7.2.0"
  }
}
